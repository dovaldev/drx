    "s": "section",
    "d": "div",
    "sp": "span",
    "btn": "button",
    "hdr": "header",
    "ftr": "footer",
    "art": "article",
    "frm": "form",
    "lbl": "label",
    "inp": "input",
    "ta": "textarea",
