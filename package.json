{
  "name": "@dovaldev/drx",
  "version": "0.1.1",
  "description": "DRX compiler for React and Next.js projects",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "license": "MIT",
  "author": "Juan A. Doval",
  "homepage": "https://github.com/dovaldev/drx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dovaldev/drx.git"
  },
  "bugs": {
    "url": "https://github.com/dovaldev/drx/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "nextjs",
    "tsx",
    "compiler",
    "ai",
    "drx",
    "dovreact"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms.txt"
  ],
  "bin": {
    "drx": "dist/cli.js",
    "dovreact": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean --external typescript",
    "prepublishOnly": "pnpm check && pnpm test && pnpm build",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "5.0.0",
    "commander": "14.0.3",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.5",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.6.2",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "vitest": "4.1.6"
  }
}
